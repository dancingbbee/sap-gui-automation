#!/usr/bin/env python3
"""sapctl — CLI client for the SAP GUI daemon (sap-daemon.js).

The daemon listens on 127.0.0.1:18765 inside a running SAP GUI for Java
process. Every request (except health) carries the token from
~/.sap-daemon/token.

Examples:
    sapctl health
    sapctl exec 'application.findById("/app/con[0]/ses[0]").info.getUser()'
    sapctl snapshot --id '/app/con[0]/ses[0]/wnd[0]/usr' --depth 3
    sapctl screenshot --match 100-100 -o /tmp/mat.png
    sapctl transact steps.json        # steps.json = {"steps":[...]} or [...]
"""
import argparse
import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.error

HOST = os.environ.get("SAP_DAEMON_HOST", "127.0.0.1")
PORT = int(os.environ.get("SAP_DAEMON_PORT", "18765"))
TOKEN_PATH = os.path.expanduser("~/.sap-daemon/token")
LAUNCHER = os.path.expanduser("~/Applications/SAP (daemon).app")


def token():
    try:
        with open(TOKEN_PATH) as f:
            return f.read().strip()
    except FileNotFoundError:
        return None


def call(method, path, body=None, timeout=30):
    url = f"http://{HOST}:{PORT}{path}"
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Content-Type", "application/json")
    tok = token()
    if tok:
        req.add_header("X-Token", tok)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        try:
            return json.loads(e.read().decode())
        except Exception:
            return {"ok": False, "error": f"HTTP {e.code}"}
    except urllib.error.URLError as e:
        return {"ok": False, "error": f"connect failed: {e.reason} "
                                      f"(is SAP GUI running with sap-daemon.js?)"}


def emit(obj, raw=False):
    if raw:
        print(json.dumps(obj, ensure_ascii=False))
    else:
        print(json.dumps(obj, ensure_ascii=False, indent=2))
    return 0 if obj.get("ok") else 1


# ---- lifecycle (local process management; separate from the HTTP layer) ----
# The daemon lives INSIDE the SAP GUI JVM. It has no independent lifecycle:
# starting it = launching SAP GUI with -f; stopping it = killing that JVM
# (which also closes the user's logged-in sessions).

def daemon_pid():
    """PID of the SAP GUI JVM holding port 18765, or None."""
    try:
        out = subprocess.run(["lsof", "-nP", "-iTCP:%d" % PORT, "-sTCP:LISTEN", "-t"],
                             capture_output=True, text=True, timeout=10).stdout.strip()
        return int(out.splitlines()[0]) if out else None
    except Exception:
        return None


def cmd_status(timeout):
    pid = daemon_pid()
    if pid is None:
        return {"ok": False, "running": False,
                "error": "daemon not running (no listener on %d). Use 'sapctl start'." % PORT}
    h = call("GET", "/health", timeout=timeout)
    h["running"] = True
    h["pid"] = pid
    if h.get("conns", 0) == 0:
        h["hint"] = "daemon up but no SAP login. Double-click a system in the Logon Pad."
    return h


def cmd_start(timeout):
    if daemon_pid() is not None:
        return {"ok": True, "running": True, "note": "already running",
                "status": call("GET", "/health", timeout=timeout)}
    if not os.path.exists(LAUNCHER):
        return {"ok": False, "error": "launcher not found at %s — run install.sh first" % LAUNCHER}
    subprocess.run(["open", LAUNCHER], check=False)
    # wait for the port to come up
    for _ in range(20):
        time.sleep(0.5)
        if daemon_pid() is not None:
            return {"ok": True, "running": True,
                    "note": "started; now log in via the Logon Pad",
                    "status": call("GET", "/health", timeout=timeout)}
    return {"ok": False, "error": "launched but daemon did not bind within 10s"}

# Note: there is no stop/restart. The daemon is bound to the SAP GUI JVM's
# lifetime — quit SAP GUI (Cmd+Q) and the daemon dies with it. Managing it
# separately would only risk closing the user's logged-in sessions.


def add_target_flags(sp):
    """Target selection: by index (--con/--ses) or by name (--system/--match)."""
    sp.add_argument("--con", type=int, default=None, help="connection index")
    sp.add_argument("--ses", type=int, default=None, help="session index")
    sp.add_argument("--system", default=None, help="target by system name substring (e.g. DEV)")
    sp.add_argument("--match", default=None, help="target by window-title substring")


def target_body(args):
    body = {}
    for k in ("con", "ses", "system"):
        v = getattr(args, k, None)
        if v is not None:
            body[k] = v
    # 'match' is shared: for screenshot it's the capture target; for others it
    # selects the (con,ses). Callers merge it where appropriate.
    return body


def main():
    p = argparse.ArgumentParser(prog="sapctl", description="SAP GUI daemon client")
    p.add_argument("--raw", action="store_true", help="compact JSON output")
    p.add_argument("--timeout", type=int, default=30)
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("health", help="ping daemon (low-level)")
    sub.add_parser("targets", help="list open connections × sessions (pick one to control)")

    # lifecycle (daemon is bound to SAP GUI; quit SAP to stop it — no stop/restart)
    sub.add_parser("status", help="is the daemon running + logged in?")
    sub.add_parser("start", help="launch SAP GUI with the daemon attached")

    pe = sub.add_parser("exec", help="evaluate a JS snippet in the daemon")
    pe.add_argument("script")
    pe.add_argument("--edt", action="store_true", help="run on Swing EDT (rarely needed)")
    add_target_flags(pe)

    ps = sub.add_parser("snapshot", help="dump a UI subtree")
    ps.add_argument("--id", default=None, help="subtree id (default: target root)")
    ps.add_argument("--depth", type=int, default=10)
    add_target_flags(ps)

    pc = sub.add_parser("screenshot", help="capture a SAP window to PNG")
    pc.add_argument("-o", "--out", default=None, help="output path (default: daemon cache dir)")
    pc.add_argument("--match", default=None, help="window-title substring to capture")
    pc.add_argument("--con", type=int, default=None, help="connection index")
    pc.add_argument("--ses", type=int, default=None, help="session index")
    pc.add_argument("--system", default=None, help="capture target by system name")
    pc.add_argument("--no-enlarge", action="store_true",
                    help="capture at current window size (default: enlarge small windows for legibility)")

    pt = sub.add_parser("transact", help="run a declarative step list from a JSON file ('-' = stdin)")
    pt.add_argument("file")
    add_target_flags(pt)

    args = p.parse_args()

    if args.cmd == "health":
        return emit(call("GET", "/health", timeout=args.timeout), args.raw)
    if args.cmd == "targets":
        return emit(call("POST", "/targets", {}, timeout=args.timeout), args.raw)
    if args.cmd == "status":
        return emit(cmd_status(args.timeout), args.raw)
    if args.cmd == "start":
        return emit(cmd_start(args.timeout), args.raw)
    if args.cmd == "exec":
        body = target_body(args)
        body.update({"script": args.script, "edt": args.edt})
        if args.match is not None:
            body["match"] = args.match
        return emit(call("POST", "/exec", body, timeout=args.timeout), args.raw)
    if args.cmd == "snapshot":
        body = target_body(args)
        body["maxDepth"] = args.depth
        if args.id is not None:
            body["id"] = args.id
        if args.match is not None:
            body["match"] = args.match
        return emit(call("POST", "/snapshot", body, timeout=args.timeout), args.raw)
    if args.cmd == "screenshot":
        body = {}
        if args.out:
            body["path"] = os.path.abspath(args.out)
        for k in ("match", "con", "ses", "system"):
            v = getattr(args, k, None)
            if v is not None:
                body[k] = v
        if args.no_enlarge:
            body["enlarge"] = False
        return emit(call("POST", "/screenshot", body, timeout=args.timeout), args.raw)
    if args.cmd == "transact":
        text = sys.stdin.read() if args.file == "-" else open(args.file).read()
        parsed = json.loads(text)
        steps = parsed["steps"] if isinstance(parsed, dict) else parsed
        body = target_body(args)
        body["steps"] = steps
        if args.match is not None:
            body["match"] = args.match
        return emit(call("POST", "/transact", body, timeout=args.timeout), args.raw)
    return 2


if __name__ == "__main__":
    sys.exit(main())
