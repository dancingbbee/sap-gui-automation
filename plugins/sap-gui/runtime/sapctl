#!/usr/bin/env python3
"""sapctl — cross-platform CLI client for SAP GUI control.

Selects a backend by OS (macOS = sap-daemon.js over HTTP; Windows = win32com COM)
and exposes one interface: health/status/start/kill-orphans/targets/exec/
snapshot/screenshot/transact. The transact step JSON is the OS-neutral way to
drive SAP; `exec` (raw JS) is macOS-only.

Examples:
    sapctl health
    sapctl targets
    sapctl snapshot --id 'wnd[0]/usr' --depth 3
    sapctl screenshot --match 100-100 -o /tmp/mat.png
    sapctl transact steps.json        # steps.json = {"steps":[...]} or [...]
"""
import argparse
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from backends import select_backend


def emit(obj, raw=False):
    if raw:
        print(json.dumps(obj, ensure_ascii=False))
    else:
        print(json.dumps(obj, ensure_ascii=False, indent=2))
    return 0 if obj.get("ok") else 1


def add_target_flags(sp):
    """Target selection: by index (--con/--ses) or by name (--system/--match)."""
    sp.add_argument("--con", type=int, default=None, help="connection index")
    sp.add_argument("--ses", type=int, default=None, help="session index")
    sp.add_argument("--system", default=None, help="target by system name substring (e.g. DEV)")
    sp.add_argument("--match", default=None, help="target by window-title substring")


def target_body(args):
    body = {}
    for k in ("con", "ses", "system"):
        v = getattr(args, k, None)
        if v is not None:
            body[k] = v
    return body


def main():
    p = argparse.ArgumentParser(prog="sapctl", description="SAP GUI control client (macOS/Windows)")
    p.add_argument("--raw", action="store_true", help="compact JSON output")
    p.add_argument("--timeout", type=int, default=30)
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("health", help="ping daemon / check COM attach")
    sub.add_parser("targets", help="list open connections × sessions (pick one to control)")

    # lifecycle
    sub.add_parser("status", help="is SAP control available + logged in?")
    sub.add_parser("start", help="launch SAP (macOS: daemon app; Windows: guidance)")
    pko = sub.add_parser("kill-orphans",
                         help="kill leftover SAP processes with no windows (macOS only)")
    pko.add_argument("--dry-run", action="store_true", help="list what would be killed, don't kill")

    pe = sub.add_parser("exec", help="evaluate a JS snippet (macOS only)")
    pe.add_argument("script")
    pe.add_argument("--edt", action="store_true", help="run on Swing EDT (rarely needed)")
    add_target_flags(pe)

    ps = sub.add_parser("snapshot", help="dump a UI subtree")
    ps.add_argument("--id", default=None, help="subtree id (default: target root)")
    ps.add_argument("--depth", type=int, default=10)
    add_target_flags(ps)

    pc = sub.add_parser("screenshot", help="capture a SAP window to PNG")
    pc.add_argument("-o", "--out", default=None, help="output path")
    pc.add_argument("--match", default=None, help="window-title substring to capture")
    pc.add_argument("--con", type=int, default=None, help="connection index")
    pc.add_argument("--ses", type=int, default=None, help="session index")
    pc.add_argument("--system", default=None, help="capture target by system name")
    pc.add_argument("--no-enlarge", action="store_true",
                    help="capture at current size (macOS: skip off-screen enlarge)")

    pt = sub.add_parser("transact", help="run a declarative step list from a JSON file ('-' = stdin)")
    pt.add_argument("file")
    add_target_flags(pt)

    args = p.parse_args()
    be = select_backend()

    if args.cmd == "health":
        return emit(be.health(args.timeout), args.raw)
    if args.cmd == "targets":
        return emit(be.targets(args.timeout), args.raw)
    if args.cmd == "status":
        return emit(be.status(args.timeout), args.raw)
    if args.cmd == "start":
        return emit(be.start(args.timeout), args.raw)
    if args.cmd == "kill-orphans":
        return emit(be.kill_orphans(args.dry_run), args.raw)
    if args.cmd == "exec":
        body = target_body(args)
        body.update({"script": args.script, "edt": args.edt})
        if args.match is not None:
            body["match"] = args.match
        return emit(be.exec_(body, args.timeout), args.raw)
    if args.cmd == "snapshot":
        body = target_body(args)
        body["maxDepth"] = args.depth
        if args.id is not None:
            body["id"] = args.id
        if args.match is not None:
            body["match"] = args.match
        return emit(be.snapshot(body, args.timeout), args.raw)
    if args.cmd == "screenshot":
        body = {}
        if args.out:
            body["path"] = os.path.abspath(args.out)
        for k in ("match", "con", "ses", "system"):
            v = getattr(args, k, None)
            if v is not None:
                body[k] = v
        if args.no_enlarge:
            body["enlarge"] = False
        return emit(be.screenshot(body, args.timeout), args.raw)
    if args.cmd == "transact":
        text = sys.stdin.read() if args.file == "-" else open(args.file).read()
        parsed = json.loads(text)
        steps = parsed["steps"] if isinstance(parsed, dict) else parsed
        body = target_body(args)
        body["steps"] = steps
        if args.match is not None:
            body["match"] = args.match
        return emit(be.transact(body, args.timeout), args.raw)
    return 2


if __name__ == "__main__":
    sys.exit(main())
